---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props { title?: string; }
const { title = "박명재 | 프론트엔드 개발자" } = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  <link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
  <meta name="description" content="측정 기반의 성능 최적화와 팀 전체가 유지할 수 있는 아키텍처를 설계하는 프론트엔드 개발자 박명재의 포트폴리오입니다." />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" />
</head>
<body>

  <Header />

  <main>
    <slot />
    <Footer />
  </main>

</body>

<style is:global>
  :root {
    --bg: #fafafa;
    --surface: #ffffff;
    --ink: #171717;
    --ink-soft: #3f3f46;
    --muted: #71717a;
    --faint: #a1a1aa;
    --line: #e8e8e6;
    --line-2: #dcdcd9;
    --accent: #16a34a;
    --accent-2: #22c55e;
    --accent-tint: #f1faf3;
    --accent-line: #cdeed6;
    --code-bg: #f4f4f2;
    --mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    --sans: 'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
    font-family: var(--sans);
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  h1, h2, h3, h4, p, figure { margin: 0; }
  a { color: inherit; text-decoration: none; }

  code {
    font-family: var(--mono);
    font-size: 0.84em;
    background: var(--code-bg);
    border: 1px solid var(--line);
    padding: 1px 6px;
    border-radius: 5px;
    color: #0f3d24;
    overflow-wrap: anywhere;
  }

  ::selection { background: var(--accent-2); color: #fff; }

  @keyframes blink {
    0%, 48% { opacity: 1; }
    49%, 100% { opacity: 0; }
  }

  @media print {
    html { scroll-behavior: auto; }
    * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
    header { display: none !important; }
    #pm-progress { display: none !important; }
    [data-reveal] { opacity: 1 !important; transform: none !important; transition: none !important; }
    #top { padding-top: 6mm !important; }
    section { padding-top: 9mm !important; padding-bottom: 9mm !important; }
    article, figure { break-inside: avoid; }
    h2, h3, h4 { break-after: avoid; }
    img { max-height: 150mm !important; }
    @page { size: A4; margin: 12mm; }
  }
</style>

<script>
  function initRevealAnimation() {
    const io = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((en) => {
          if (en.isIntersecting) {
            const el = en.target as HTMLElement;
            el.style.opacity = '1';
            el.style.transform = 'none';
            obs.unobserve(en.target);
          }
        });
      },
      { rootMargin: '0px 0px -7% 0px', threshold: 0.05 }
    );

    document.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el) => {
      el.style.transition = 'opacity .6s cubic-bezier(.22,.61,.36,1), transform .6s cubic-bezier(.22,.61,.36,1)';
      el.style.opacity = '0';
      el.style.transform = 'translateY(14px)';
      io.observe(el);
    });
  }

  initRevealAnimation();
</script>

</html>
